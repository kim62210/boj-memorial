# PostgreSQL connection string (required in production).
# Example: postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# Comma-separated list of allowed origins for CORS / Socket.IO handshake.
# Leave empty in local dev; must be explicit in production.
# Example: https://boj-memorial.example.com,https://staging.example.com
ALLOWED_ORIGINS=

# HTTP server port. Defaults to 3000 if unset; project convention is 4100.
PORT=4100

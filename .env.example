# PostgreSQL connection string (required in production).
# Example: postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# Comma-separated list of allowed origins for Socket.IO / CORS handshake.
# Leave empty in local dev (custom server allows all origins in dev); must be explicit in production.
# Example: https://boj-memorial.brian-dev.cloud,https://boj-memorial.duckdns.org
ALLOWED_ORIGINS=

# HTTP server port. Defaults to 4100 (project convention).
PORT=4100

# Hostname to bind the HTTP server to. Defaults to 0.0.0.0.
HOSTNAME=0.0.0.0

# Graceful shutdown drain window (ms) for existing Socket.IO sessions on SIGTERM.
# Default: 30000 (30s). Cady upstream close delay 은 동일/더 큰 값으로 맞출 것.
SHUTDOWN_DRAIN_MS=30000

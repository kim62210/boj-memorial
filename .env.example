# Copy to .env.local and fill in actual values. Never commit .env.local.

# --- Runtime ---
NODE_ENV=development

# --- Public (브라우저 노출, NEXT_PUBLIC_ 접두어 필수) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Server-only ---
# PostgreSQL 연결 문자열 (Drizzle 도입 시 이 키를 사용한다)
DATABASE_URL=postgres://user:password@localhost:5432/boj_memorial

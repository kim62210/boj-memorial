{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "incremental": false,
    "isolatedModules": false,
    "jsx": "preserve",
    "lib": ["ES2022"],
    "types": ["node"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["server.ts", "instrumentation.ts", "lib/**/*.ts", "db/**/*.ts"],
  "exclude": ["node_modules", ".next", "app", "components", "dist", "scripts", "**/*.test.ts"]
}
